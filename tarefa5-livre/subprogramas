def mostrar_menu():
    print("\n SISTEMA DE ESTOQUE ")
    print("1 - Cadastrar produto")
    print("2 - Adicionar ao estoque")
    print("3 - Retirar do estoque")
    print("4 - Consultar produto")
    print("5 - Listar produtos")
    print("6 - Remover produto")
    print("0 - Sair")


def ler_opcao():
    return input("Selecione uma opção: ")


def cadastrar_produto(estoque):
    codigo_prod = input("Código do produto: ")

    if codigo_prod in estoque:
        print("O produto já está cadastrado!")
        return

    nome = input("Digite o nome do produto: ")
    preco = float(input("Digite o preço do produto: "))
    quantidade = int(input("Quantidade inicial: "))

    estoque[codigo_prod] = {
        "nome": nome,
        "preco": preco,
        "quantidade": quantidade
    }

    print("O produto foi cadastrado com sucesso!")


def atualizar_qtd(estoque, codigo_prod, quantidade, tipo):
    if codigo_prod not in estoque:
        print("O produto não foi encontrado!")
        return False

    if tipo == "entrada":
        estoque[codigo_prod]["quantidade"] += quantidade
        return True

    elif tipo == "saida":
        if estoque[codigo_prod]["quantidade"] < quantidade:
            print("Erro: estoque insuficiente!")
            return False
        estoque[codigo_prod]["quantidade"] -= quantidade
        return True

    return False


def adicionar_estoque(estoque):
    codigo_prod = input("Código do produto: ")
    quantidade = int(input("Quantidade para adicionar: "))

    if atualizar_qtd(estoque, codigo_prod, quantidade, "entrada"):
        print("Adicionado com sucesso!")


